{
  "manifest_version": 3,
  "name": "OneResume Connect",
  "version": "1.1.3",
  "description": "OneResume 마스터 이력서를 채용 사이트에 자동으로 동기화합니다.",
  "permissions": ["storage", "activeTab", "scripting", "webNavigation"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://api.oneresume.kr/*",
    "*://localhost/*",
    "*://*.saramin.co.kr/*",
    "*://*.jobkorea.co.kr/*",
    "*://*.wanted.co.kr/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/logo.png",
      "32": "icons/logo.png",
      "48": "icons/logo.png",
      "128": "icons/logo.png"
    }
  },
  "icons": {
    "16": "icons/logo.png",
    "32": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://localhost/*",
        "*://*.oneresume.kr/*",
        "*://*.saramin.co.kr/*",
        "*://*.jobkorea.co.kr/*",
        "*://*.wanted.co.kr/*"
      ],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/logo.png", "icons/saramin.webp"],
      "matches": ["*://*.saramin.co.kr/*", "*://*.jobkorea.co.kr/*", "*://*.wanted.co.kr/*"]
    }
  ]
}
