{
  "manifest_version": 3,
  "name": "OneResume Connect",
  "version": "1.1.8",
  "description": "OneResume 이력서로 사람인, 잡코리아 1초 자동 입력! AI 채용공고 분석과 맞춤형 자소서 생성까지 한 번에 해결하세요.",
  "permissions": ["storage", "activeTab", "webNavigation"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://api.oneresume.kr/*",
    "*://localhost/*",
    "*://oneresume.kr/*",
    "*://*.oneresume.kr/*",
    "*://*.saramin.co.kr/*",
    "*://*.jobkorea.co.kr/*",
    "*://*.wanted.co.kr/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/logo16.png",
      "32": "icons/logo32.png",
      "48": "icons/logo48.png",
      "128": "icons/logo128.png"
    }
  },
  "icons": {
    "16": "icons/logo16.png",
    "32": "icons/logo32.png",
    "48": "icons/logo48.png",
    "128": "icons/logo128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://localhost/*",
        "*://oneresume.kr/*",
        "*://*.oneresume.kr/*",
        "*://*.saramin.co.kr/*",
        "*://*.jobkorea.co.kr/*",
        "*://*.wanted.co.kr/*"
      ],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/logo.png", "icons/logo16.png", "icons/logo32.png", "icons/logo48.png", "icons/logo128.png", "icons/saramin.webp"],
      "matches": ["*://*.saramin.co.kr/*", "*://*.jobkorea.co.kr/*", "*://*.wanted.co.kr/*"]
    }
  ]
}
