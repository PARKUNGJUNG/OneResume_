generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int       @id @default(autoincrement())
  email                String    @unique
  password             String?
  username             String?
  subdomain            String    @unique
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  bio                  String?
  blogUrl              String?
  githubUrl            String?
  profileImage         String?
  profileImageUrl      String?
  isVerified           Boolean   @default(false)
  provider             String    @default("LOCAL")
  socialId             String?   @unique
  verificationToken    String?
  resetPasswordExpires DateTime?
  resetPasswordToken   String?
  age                  Int?
  isProfileComplete    Boolean   @default(false)
  phone                String?
  gender               String?
  address              String?
  addressDetail        String?
  useInternationalAge  Boolean   @default(false)
  job                  String?
  resumes              Resume[]
}

model Resume {
  id                  Int              @id @default(autoincrement())
  title               String
  theme               String           @default("classic")
  userId              Int
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  education           String?
  skills              String?
  militaryStatus      String?
  selfIntroCharacter  String?          @db.Text
  selfIntroGrowth     String?          @db.Text
  selfIntroMotivation String?          @db.Text
  militaryBranch      String?
  militaryEndDate     String?
  militaryExemption   String?
  militaryRank        String?
  militaryStartDate   String?
  sectionOrder        String?          @default("edu,skills,experience,projects,certs,extra")
  certifications      Certification[]
  projects            Project[]
  user                User             @relation(fields: [userId], references: [id])
  workExperiences     WorkExperience[]

  @@index([userId], map: "Resume_userId_fkey")
}

model WorkExperience {
  id             Int     @id @default(autoincrement())
  companyName    String
  department     String?
  role           String?
  jobDescription String? @db.Text
  period         String?
  isCurrent      Boolean @default(false)
  resumeId       Int
  position       String?
  resume         Resume  @relation(fields: [resumeId], references: [id])

  @@index([resumeId], map: "WorkExperience_resumeId_fkey")
}

model Certification {
  id       Int     @id @default(autoincrement())
  type     String  @default("CERT")
  name     String
  issuer   String?
  date     String?
  score    String?
  resumeId Int
  resume   Resume  @relation(fields: [resumeId], references: [id])

  @@index([resumeId], map: "Certification_resumeId_fkey")
}

model Project {
  id          Int     @id @default(autoincrement())
  name        String
  description String? @db.Text
  techStack   String?
  githubUrl   String?
  resumeId    Int
  period      String?
  role        String?
  resume      Resume  @relation(fields: [resumeId], references: [id])

  @@index([resumeId], map: "Project_resumeId_fkey")
}
